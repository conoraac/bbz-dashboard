# ---- BBZ Performance Dashboard — environment variables ----

# REQUIRED for the AI Q&A box (kept server-side, never sent to the browser)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — enables ALWAYS-LIVE GA4 data. Without it, the page runs on the
# bundled snapshot (still fully interactive, just frozen at the last pull).
WINDSOR_API_KEY=your-windsor-ai-api-key

# BBZ's GA4 property id in Windsor (default already set)
GA4_ACCOUNT=309061594

# Optional model override (defaults to claude-sonnet-4-6; try claude-haiku-4-5-20251001 for speed)
MODEL=claude-sonnet-4-6

# --- additional report sections ---
GBP_ACCOUNT=locations/8839500927202128335
# BBZ's CallRail account in Windsor. Changes on every reconnect (now 648); re-verify if calls vanish.
CALLRAIL_ACCOUNT=648
# CallRail returns per-call rows; pulling many months is slow. Default 6.
CALLRAIL_MONTHS=6
GSC_ACCOUNT=sc-domain:bbzlimo.com
